generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Case {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  status      String     @default("ACTIVE")
  threatLevel String     @default("ELEVATED")
  openedAt    DateTime
  updatedAt   DateTime   @updatedAt
  emails      Email[]
  chats       Chat[]
  documents   Document[]
  media       Media[]
  logs        Log[]

  @@map("cases")
}

model Email {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromName    String
  fromEmail   String
  toName      String
  toEmail     String
  subject     String
  body        String
  folder      String   @default("Inbox")
  sentAt      DateTime
  isFlagged   Boolean  @default(false)
  order       Int      @default(0)

  @@map("emails")
}

model Chat {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  channel     String
  sender      String
  handle      String
  message     String
  sentAt      DateTime
  sequence    Int
  isEncrypted Boolean  @default(false)

  @@map("chats")
}

model Document {
  id             String   @id @default(cuid())
  caseId         String
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title          String
  category       String
  classification String   @default("Internal")
  author         String
  content        String
  tags           String   @default("")
  createdAt      DateTime
  isFlagged      Boolean  @default(false)

  @@map("documents")
}

model Media {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title       String
  type        String
  url         String
  caption     String
  source      String
  capturedAt  DateTime
  isFlagged   Boolean  @default(false)

  @@map("media")
}

model Log {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  level      String
  source     String
  code       String
  message    String
  occurredAt DateTime

  @@map("logs")
}
