{
	"name": "deadsignal",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"db:generate": "prisma generate",
		"db:migrate": "cross-env RUST_LOG=info prisma migrate dev",
		"db:push": "cross-env RUST_LOG=info prisma db push",
		"db:seed": "prisma db seed",
		"db:reset": "cross-env RUST_LOG=info prisma migrate reset"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.3",
		"cross-env": "^10.1.0",
		"dotenv": "^17.4.2",
		"prisma": "^7.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@lucide/svelte": "^1.18.0",
		"@prisma/adapter-better-sqlite3": "^7.8.0",
		"@prisma/client": "^7.8.0"
	}
}
